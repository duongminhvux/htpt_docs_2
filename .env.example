# =========================================================
# COMMON CONFIG
# =========================================================

POSTGRES_DB=htpt_docs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

SECRET_KEY=change-this-secret-key # Hãy thay đổi giá trị này trong môi trường production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

FRONTEND_URL=http://localhost:5173

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws


# =========================================================
# OPTION 1: RUN BACKEND INSIDE DOCKER
# Dùng block này khi chạy:
# docker compose up --build
# =========================================================

DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/htpt_docs

REDIS_URL=redis://redis:6379/0

RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/


# =========================================================
# OPTION 2: RUN BACKEND LOCAL ON WINDOWS
# Nếu chạy backend trực tiếp bằng uvicorn trên máy thật,
# hãy comment block Docker ở trên và mở block này.
# =========================================================

# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/htpt_docs

# REDIS_URL=redis://localhost:6379/0

# RABBITMQ_USER=guest
# RABBITMQ_PASS=guest
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/