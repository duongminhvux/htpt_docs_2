# =========================================================
# COMMON CONFIG
# =========================================================

POSTGRES_DB=htpt_docs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Khi chạy qua nginx thì frontend chính là localhost:8080
FRONTEND_URL=http://localhost:8080

# Cho phép test local FE 5173, nginx 8080, backend 8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8000,http://127.0.0.1:8000

# Dùng khi mở frontend trực tiếp qua Vite port 5173
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws


# =========================================================
# OPTION 1: BACKEND RUNS INSIDE DOCKER
# Dùng khi chạy: docker compose up --build
# =========================================================

DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/htpt_docs
REDIS_URL=redis://redis:6379/0

RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/


# =========================================================
# OPTION 2: BACKEND RUNS LOCAL ON WINDOWS
# Nếu chạy backend bằng uvicorn trên máy thật,
# hãy comment 3 dòng Docker ở trên và mở 3 dòng dưới.
# =========================================================

# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/htpt_docs
# REDIS_URL=redis://localhost:6379/0
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/