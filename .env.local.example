# Local mode: PostgreSQL, Redis, RabbitMQ, Backend, Worker, Frontend đều chạy trên máy
POSTGRES_DB=htpt_docs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/htpt_docs
REDIS_URL=redis://localhost:6379/0

RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws
